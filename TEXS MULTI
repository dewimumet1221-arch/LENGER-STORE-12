local LocalPlayer = Players.LocalPlayer
local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
local RootPart = Character:WaitForChild("HumanoidRootPart")

-- Pengaturan
local Settings = {
    AutoFarm = false,
    ESP = false,
    NoClip = false,
    AntiDeath = false,
    SafePos = Vector3.new(0,5,0),
    TeleportLocations = {
        ["Tempat 1"] = CFrame.new(100,5,100),
        ["Tempat 2"] = CFrame.new(200,5,200),
        ["Tempat Aman"] = CFrame.new(0,5,0)
    }
}

-- ==================================================
-- SISTEM TEMBUS DINDING
-- ==================================================
local NC_CollideData = {}
local oldMeta = getrawmetatable(game)
local oldIndex = oldMeta.__index
setreadonly(oldMeta,false)

oldMeta.__index = function(self,idx)
    if idx == "CanCollide" and typeof(self)=="Instance" and NC_CollideData[self.Name]~=nil then
        return NC_CollideData[self.Name]
    end
    return oldIndex(self,idx)
end

local function UpdateNoClip()
    if not Settings.NoClip then return end
    for _,part in ipairs(Character:GetDescendants()) do
        if part:IsA("BasePart") then
            NC_CollideData[part.Name] = NC_CollideData[part.Name] or part.CanCollide
            part.CanCollide = false
        end
    end
end

RunService.RenderStepped:Connect(UpdateNoClip)

